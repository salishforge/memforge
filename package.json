{
  "name": "@salishforge/memforge",
  "version": "2.2.0",
  "description": "Neuroscience-inspired agent memory — sleep cycles, memory revision, knowledge graph, procedural learning, vector search, and MCP integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./tools": {
      "import": "./dist/tool-definitions.js",
      "types": "./dist/tool-definitions.d.ts"
    }
  },
  "bin": {
    "memforge": "./dist/server.js",
    "memforge-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "mcp": "node dist/mcp.js",
    "migrate": "psql \"$DATABASE_URL\" -f schema/schema.sql",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test:cache": "node --import tsx/esm --test tests/cache.test.ts",
    "test:integration": "node --import tsx/esm --test tests/integration.test.ts",
    "test:llm": "node --import tsx/esm --test tests/llm-paths.test.ts",
    "test:http": "node --import tsx/esm --test tests/http-api.test.ts",
    "test:load": "node --import tsx/esm --test tests/load.test.ts",
    "test:security": "node --import tsx/esm --test tests/security.test.ts",
    "test": "node --import tsx/esm --test tests/integration.test.ts tests/llm-paths.test.ts tests/http-api.test.ts tests/cache.test.ts",
    "benchmark:longmemeval": "node --import tsx/esm benchmarks/longmemeval/run.ts",
    "benchmark:download": "node --import tsx/esm benchmarks/longmemeval/download.ts",
    "benchmark:ingest": "node --import tsx/esm benchmarks/longmemeval/ingest.ts",
    "benchmark:evaluate": "node --import tsx/esm benchmarks/longmemeval/evaluate.ts",
    "benchmark:report": "node --import tsx/esm benchmarks/longmemeval/report.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.10",
    "@types/pg": "^8.11.10",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schema",
    ".env.example",
    "README.md"
  ],
  "keywords": [
    "memory",
    "agent",
    "ai",
    "postgresql",
    "vector-search",
    "knowledge-graph",
    "mcp",
    "llm",
    "tiered-memory",
    "reflection"
  ],
  "author": "SalishForge (https://github.com/salishforge)",
  "repository": {
    "type": "git",
    "url": "https://github.com/salishforge/memforge.git"
  },
  "homepage": "https://github.com/salishforge/memforge#readme",
  "bugs": {
    "url": "https://github.com/salishforge/memforge/issues"
  },
  "license": "MIT"
}
