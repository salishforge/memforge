{
  "name": "@salishforge/memforge",
  "version": "1.0.0",
  "description": "Tiered agent memory service — hot/warm/cold PostgreSQL storage with FTS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "memforge": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "psql \"$DATABASE_URL\" -f schema/schema.sql",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.10",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schema",
    ".env.example",
    "README.md"
  ],
  "keywords": [
    "memory",
    "agent",
    "ai",
    "postgresql",
    "fts",
    "tiered-memory"
  ],
  "license": "MIT"
}
