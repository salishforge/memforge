{
  "name": "@salishforge/memforge",
  "version": "3.7.0",
  "description": "Neuroscience-inspired agent memory — sleep cycles, memory revision, knowledge graph, procedural learning, vector search, and MCP integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./tools": {
      "import": "./dist/tool-definitions.js",
      "types": "./dist/tool-definitions.d.ts"
    }
  },
  "bin": {
    "memforge": "./dist/server.js",
    "memforge-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "mcp": "node dist/mcp.js",
    "migrate": "psql \"$DATABASE_URL\" -f schema/schema.sql",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test:cache": "node --import tsx/esm --test tests/cache.test.ts",
    "test:integration": "node --import tsx/esm --test tests/integration.test.ts",
    "test:llm": "node --import tsx/esm --test tests/llm-paths.test.ts",
    "test:http": "node --import tsx/esm --test tests/http-api.test.ts",
    "test:load": "node --import tsx/esm --test tests/load.test.ts",
    "test:security": "node --import tsx/esm --test tests/security.test.ts",
    "test:embedding-migration": "node --import tsx/esm --test tests/embedding-migration.test.ts",
    "test:outcome-revision": "node --import tsx/esm --test tests/outcome-revision.test.ts",
    "test:reflection-revision": "node --import tsx/esm --test tests/reflection-revision.test.ts",
    "test:selective-forgetting": "node --import tsx/esm --test tests/selective-forgetting.test.ts",
    "test:dream-runs": "node --import tsx/esm --test tests/dream-runs.test.ts",
    "test:dreams-compat": "node --import tsx/esm --test tests/dreams-compat.test.ts",
    "test:dreams-anthropic": "node --import tsx/esm --test tests/dreams-anthropic.test.ts",
    "test:dreams-bridge": "node --import tsx/esm --test tests/dreams-bridge.test.ts",
    "test": "node --import tsx/esm --test --test-concurrency=1 tests/integration.test.ts tests/llm-paths.test.ts tests/http-api.test.ts tests/cache.test.ts tests/embedding-migration.test.ts tests/outcome-revision.test.ts tests/reflection-revision.test.ts tests/selective-forgetting.test.ts tests/multi-device.test.ts tests/dream-runs.test.ts tests/dreams-compat.test.ts tests/dreams-anthropic.test.ts tests/dreams-bridge.test.ts tests/sentiment-tagging.test.ts tests/adaptive-sleep.test.ts tests/epistemic-confidence.test.ts",
    "test:multi-device": "node --import tsx/esm --test tests/multi-device.test.ts",
    "test:sentiment-tagging": "node --import tsx/esm --test tests/sentiment-tagging.test.ts",
    "test:adaptive-sleep": "node --import tsx/esm --test tests/adaptive-sleep.test.ts",
    "test:epistemic-confidence": "node --import tsx/esm --test tests/epistemic-confidence.test.ts",
    "benchmark:longmemeval": "node --import tsx/esm benchmarks/longmemeval/run.ts",
    "benchmark:download": "node --import tsx/esm benchmarks/longmemeval/download.ts",
    "benchmark:ingest": "node --import tsx/esm benchmarks/longmemeval/ingest.ts",
    "benchmark:evaluate": "node --import tsx/esm benchmarks/longmemeval/evaluate.ts",
    "benchmark:report": "node --import tsx/esm benchmarks/longmemeval/report.ts"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schema",
    ".env.example",
    "README.md"
  ],
  "keywords": [
    "memory",
    "agent",
    "ai",
    "postgresql",
    "vector-search",
    "knowledge-graph",
    "mcp",
    "llm",
    "tiered-memory",
    "reflection"
  ],
  "author": "SalishForge (https://github.com/salishforge)",
  "repository": {
    "type": "git",
    "url": "https://github.com/salishforge/memforge.git"
  },
  "homepage": "https://github.com/salishforge/memforge#readme",
  "bugs": {
    "url": "https://github.com/salishforge/memforge/issues"
  },
  "license": "MIT"
}
