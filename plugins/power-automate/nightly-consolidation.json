{
  "name": "MemForge: Nightly Consolidation & Sleep Cycle",
  "description": "Run consolidation and sleep cycle at 2:00 AM daily to maintain memory quality",
  "trigger": {
    "type": "Recurrence",
    "inputs": {
      "frequency": "Day",
      "interval": 1,
      "startTime": "2026-01-01T02:00:00Z",
      "timeZone": "UTC"
    }
  },
  "actions": [
    {
      "name": "Consolidate",
      "type": "Http",
      "inputs": {
        "method": "POST",
        "uri": "@{parameters('MemForgeUrl')}/memory/@{parameters('AgentId')}/consolidate",
        "headers": {
          "Authorization": "Bearer @{parameters('MemForgeToken')}",
          "Content-Type": "application/json"
        },
        "body": {}
      }
    },
    {
      "name": "SleepCycle",
      "type": "Http",
      "runAfter": "Consolidate",
      "inputs": {
        "method": "POST",
        "uri": "@{parameters('MemForgeUrl')}/memory/@{parameters('AgentId')}/sleep",
        "headers": {
          "Authorization": "Bearer @{parameters('MemForgeToken')}",
          "Content-Type": "application/json"
        },
        "body": {
          "tokenBudget": 50000,
          "includeReflection": true
        }
      }
    }
  ],
  "parameters": {
    "MemForgeUrl": {
      "type": "string",
      "defaultValue": "https://your-memforge-server:3333"
    },
    "MemForgeToken": {
      "type": "string"
    },
    "AgentId": {
      "type": "string",
      "defaultValue": "copilot-agent"
    }
  }
}
